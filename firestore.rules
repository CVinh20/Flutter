rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ==================== HELPER FUNCTIONS ====================
    
    // Kiểm tra xem user đã đăng nhập chưa
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Kiểm tra xem user có phải là admin không
    function isAdmin() {
      // TODO: In production, verify admin role from MongoDB backend
      // For development, allow all authenticated users
      return true;
    }
    
    // Kiểm tra xem user có phải là stylist không
    function isStylist() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.stylistId != null;
    }
    
    // Kiểm tra xem user có phải là employee không
    function isEmployee() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/employees/{document=**}) &&
        get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.userId == request.auth.uid;
    }
    
    // Kiểm tra xem user có phải là stylist của booking này không
    function isBookingStylist(bookingData) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.stylistId != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.stylistId == bookingData.stylistId;
    }
    
    // Kiểm tra xem stylist hiện tại có phải là stylist của booking không (dùng cho update)
    function isStylistOfBooking() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.stylistId != null &&
        resource.data.stylistId != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.stylistId == resource.data.stylistId;
    }
    
    // Kiểm tra xem user có phải là chủ của payment không
    function isPaymentOwner(paymentData) {
      return isAuthenticated() && paymentData.userId == request.auth.uid;
    }
    
    // ==================== COLLECTION RULES ====================
    
    // Rules cho collection users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;  // User tạo tài khoản của chính mình
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      allow delete: if isAdmin();
      
      // Rules cho subcollection savedVouchers
      match /savedVouchers/{voucherId} {
        // User chỉ có thể đọc/ghi voucher đã lưu của chính mình
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    // Rules cho collection employees (MỚI)
    match /employees/{employeeId} {
      allow read: if isAuthenticated();  // Tất cả user đã đăng nhập có thể đọc
      allow create: if isAdmin();  // Chỉ admin mới tạo được employee
      allow update: if isAdmin() || (
        isAuthenticated() && 
        resource.data.userId == request.auth.uid  // Employee có thể update thông tin của mình
      );
      allow delete: if isAdmin();  // Chỉ admin mới xóa được
    }
    
    // Rules cho collection bookings
    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() || 
        isStylistOfBooking()
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
    }
    
    // Rules cho collection services
    match /services/{serviceId} {
      allow read: if true;  // Cho phép đọc công khai
      allow write: if isAdmin();
    }
    
    // Rules cho collection branches
    match /branches/{branchId} {
      allow read: if true;  // Cho phép đọc công khai
      allow write: if isAdmin();
    }
    
    // Rules cho collection stylists
    match /stylists/{stylistId} {
      allow read: if true;  // Cho phép đọc công khai
      allow write: if isAdmin();
    }
    
    // Rules cho collection categories
    match /categories/{categoryId} {
      allow read: if true;  // Cho phép đọc công khai
      allow write: if isAdmin();
    }

    // Rules cho collection vouchers
    match /vouchers/{voucherId} {
      allow read: if true;  // Cho phép đọc công khai
      allow write: if isAdmin();  // Chỉ admin mới có thể tạo/sửa/xóa voucher
    }

    // Rules cho collection payments
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Rules cho collection transactions
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Rules cho collection paymentMethods
    match /paymentMethods/{methodId} {
      allow read: if true;  // Cho phép đọc công khai
      allow write: if isAdmin();
    }

    // Rules cho collection productCategories
    match /productCategories/{categoryId} {
      allow read: if true;  // Cho phép đọc công khai
      allow create: if isAuthenticated() && isAdmin();  // Chỉ admin app
      allow update: if isAuthenticated() && isAdmin();  // Chỉ admin app
      allow delete: if isAuthenticated() && isAdmin();  // Chỉ admin app
    }

    // Rules cho collection products
    match /products/{productId} {
      allow read: if true;  // Cho phép đọc công khai
      allow create: if isAuthenticated() && isAdmin();  // Chỉ admin app
      allow update: if isAuthenticated() && isAdmin();  // Chỉ admin app
      allow delete: if isAuthenticated() && isAdmin();  // Chỉ admin app
    }

    // Rules cho collection productReviews
    match /productReviews/{reviewId} {
      allow read: if true;  // Cho phép đọc công khai
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;  // User chỉ có thể tạo review của chính mình
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||  // User có thể sửa review của mình
        isAdmin()  // Admin có thể sửa tất cả
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||  // User có thể xóa review của mình
        isAdmin()  // Admin có thể xóa tất cả
      );
    }

    // Rules cho collection orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||  // User có thể đọc order của mình
        isAdmin()  // Admin có thể đọc tất cả
      );
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;  // User chỉ có thể tạo order của chính mình
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||  // User có thể update order của mình (trước khi thanh toán)
        isAdmin()  // Admin có thể update tất cả
      );
      allow delete: if isAdmin();  // Chỉ admin mới có thể xóa order
    }
    
    // ==================== FALLBACK RULE ====================
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}